# --- 共通設定 ---
GGUF=Llama-3.1-Swallow-8B-Instruct-v0.5-Q4_K_M
LANG=ja
MODEL_NAME=anima-ll

# --- 接続設定 ---
OLLAMA_KEEP_ALIVE=5m
OLLAMA_PORT_HOST=11434
OLLAMA_PORT_CONTAINER=11434
REQUEST_TIMEOUT=120.0
TZ=Asia/Tokyo

# --- サンプリング設定 ---
CPU_SAMPLE_INTERVAL=0.1

# --- フォーマット定数 ---
BYTES_TO_MB=1048576
ENCODING=utf-8
TIME_FORMAT=%H:%M:%S

# --- 開発者コマンド ---
COMMAND_END=exit

# --- ラベル ---
OUTPUT_LABEL=ANIMA:
INPUT_LABEL=USER:
